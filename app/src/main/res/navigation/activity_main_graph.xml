<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_main_graph"
    app:startDestination="@id/chatListFragment">

    <fragment
        android:id="@+id/chatListFragment"
        android:name="app.secure.kyber.fragments.ChatListFragment"
        android:label="fragment_chat_list"
        tools:layout="@layout/fragment_chat_list" >

        <action
            android:id="@+id/action_chatListFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>
    <fragment
        android:id="@+id/chatFragment"
        android:name="app.secure.kyber.fragments.ChatFragment"
        android:label="fragment_chat"
        tools:layout="@layout/fragment_chat" >
        <action
            android:id="@+id/action_chatFragment_to_chatDetailsFragment"
            app:destination="@id/chatDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/netwokFragment"
        android:name="app.secure.kyber.fragments.NetworkFragment"
        android:label="fragment_netwok"
        tools:layout="@layout/fragment_network" />
    <fragment
        android:id="@+id/contactsFragment"
        android:name="app.secure.kyber.fragments.ContactsFragment"
        android:label="fragment_contacts"
        tools:layout="@layout/fragment_contacts" >

    </fragment>
    <fragment
        android:id="@+id/settingFragment"
        android:name="app.secure.kyber.fragments.SettingFragment"
        android:label="fragment_setting"
        tools:layout="@layout/fragment_setting" />
    <fragment
        android:id="@+id/encryptMsgPwdFragment2"
        android:name="app.secure.kyber.fragments.EncryptMsgPwdFragment"
        android:label="EncryptMsgPwdFragment" />
    <fragment
        android:id="@+id/chatDetailsFragment"
        android:name="app.secure.kyber.fragments.ChatDetailsFragment"
        android:label="fragment_chat_details"
        tools:layout="@layout/fragment_chat_details" >
        <action
            android:id="@+id/action_chatDetailsFragment_to_sharedMediaFragment"
            app:destination="@id/sharedMediaFragment" />
    </fragment>
    <fragment
        android:id="@+id/sharedMediaFragment"
        android:name="app.secure.kyber.fragments.SharedMediaFragment"
        android:label="fragment_shared_media"
        tools:layout="@layout/fragment_shared_media" />
</navigation>