<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gradient border ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#0047AF"
                android:centerColor="#486284"
                android:endColor="#3362AB"
                android:angle="0"
                android:type="linear" />
        </shape>
    </item>

    <!-- Inner fill circle (creates the border effect) -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="#C0E7FF" />
        </shape>
    </item>

</layer-list>