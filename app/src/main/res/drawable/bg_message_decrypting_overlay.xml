<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="12dp" />

    <!-- Subtle glowing gradient behind decrypting text -->
    <gradient
        android:type="radial"
        android:gradientRadius="180dp"
        android:centerX="50%"
        android:centerY="50%"
        android:startColor="#3321C1F3"
        android:centerColor="#221C92D4"
        android:endColor="#001C92D4" />

    <!-- Very light border to make it feel like an overlay, not a full bubble -->
    <stroke
        android:width="1dp"
        android:color="#4021C1F3" />

    <padding
        android:left="4dp"
        android:top="2dp"
        android:right="4dp"
        android:bottom="2dp" />

</shape>

