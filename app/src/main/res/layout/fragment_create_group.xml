<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".fragments.CreateGroupFragment">


    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="@dimen/_16sdp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:src="@drawable/back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_16sdp"
                android:text="Create Group"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_20sdp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content - NestedScrollView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_16sdp">

            <!-- Group Details Section -->
            <TextView
                android:id="@+id/tvGroupDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginBottom="@dimen/_5sdp"
                android:letterSpacing="0.05"
                android:text="GROUP DETAILS"
                android:textColor="#A5B4FC"
                android:textSize="@dimen/_12sdp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGroupName"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:background="@drawable/group_name_edit_text_bg"
                android:hint="Enter Group Name"
                android:maxLines="1"
                android:paddingStart="@dimen/_20sdp"
                android:textColor="@android:color/white"
                android:textColorHint="#6B6B8D" />

            <!-- Anonymous Mode Card -->
            <LinearLayout
                android:id="@+id/cvAnonymousMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_30sdp"
                android:background="@drawable/anonymous_mode_bg"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ivAnonymousIcon"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/deselected_overlay_anonymous_ic" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_12sdp"
                        android:layout_toEndOf="@id/ivAnonymousIcon"
                        android:layout_toStartOf="@id/switchAnonymous"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textAnonymousMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anonymous Mode"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/_17sdp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temporary &amp; Encrypted"
                            android:textColor="#94A3B8"
                            android:textSize="@dimen/_12sdp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAnonymous"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:thumbTint="@android:color/white"
                        app:trackTint="@color/switch_track_color" />

                </RelativeLayout>

                <!-- Creator View Only Section (Initially Hidden) -->
                <LinearLayout
                    android:id="@+id/llCreatorViewOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp"
                    android:visibility="gone">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_100sdp"
                        android:background="@drawable/creator_only_view_bg"
                        android:padding="@dimen/_10sdp">

                        <ImageView
                            android:id="@+id/ivShieldIcon"
                            android:layout_width="@dimen/_30sdp"
                            android:layout_height="@dimen/_41sdp"
                            android:src="@drawable/shield_icon"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/creator_view_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:text="Creator View Only"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/_14sdp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivShieldIcon"
                            app:layout_constraintTop_toTopOf="@id/ivShieldIcon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:text="Members will see each other as &quot;Anonymous User&quot; or Pseudonyms."
                            android:textColor="#B0B0D0"
                            android:textSize="@dimen/_12sdp"
                            app:layout_constraintStart_toEndOf="@id/ivShieldIcon"
                            app:layout_constraintTop_toBottomOf="@id/creator_view_text" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Time Options -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/small_timer_ic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/small_timer_ic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_5sdp"
                                android:text="Creator View Only"
                                android:textColor="#FFFFFF"
                                android:textSize="@dimen/_12sdp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/time_buttons_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_12sdp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/hours_24"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_38sdp"
                                android:layout_marginEnd="@dimen/_4sdp"
                                android:background="@drawable/time_buttons_bg"
                                android:insetBottom="0dp"
                                android:insetTop="0dp"
                                android:text="24h"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_14sdp"
                                app:backgroundTint="@null"
                                app:cornerRadius="@dimen/_8sdp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/days_2"
                                app:layout_constraintHorizontal_weight="1"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/days_2"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_38sdp"
                                android:layout_marginHorizontal="@dimen/_4sdp"
                                android:background="@drawable/time_buttons_bg"
                                android:insetBottom="0dp"
                                android:insetTop="0dp"
                                android:text="2d"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_14sdp"
                                app:backgroundTint="@null"
                                app:cornerRadius="@dimen/_8sdp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/days_3"
                                app:layout_constraintHorizontal_weight="1"
                                app:layout_constraintStart_toEndOf="@+id/hours_24"
                                app:layout_constraintTop_toTopOf="parent" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/days_3"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_38sdp"
                                android:layout_marginHorizontal="@dimen/_4sdp"
                                android:background="@drawable/time_buttons_bg"
                                android:insetBottom="0dp"
                                android:insetTop="0dp"
                                android:text="3d"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_14sdp"
                                app:backgroundTint="@null"
                                app:cornerRadius="@dimen/_8sdp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/days_4"
                                app:layout_constraintHorizontal_weight="1"
                                app:layout_constraintStart_toEndOf="@+id/days_2"
                                app:layout_constraintTop_toTopOf="parent" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/days_4"
                                style="@style/Widget.MaterialComponents.Button"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/_38sdp"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/time_buttons_bg"
                                android:insetBottom="0dp"
                                android:insetTop="0dp"
                                android:text="4d"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_13sdp"
                                app:backgroundTint="@null"
                                app:cornerRadius="@dimen/_8sdp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintHorizontal_weight="1.2"
                                app:layout_constraintStart_toEndOf="@+id/days_3"
                                app:layout_constraintTop_toTopOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Participants Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_24sdp">

                <TextView
                    android:id="@+id/tvParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:letterSpacing="0.05"
                    android:text="PARTICIPANTS"
                    android:textColor="#A5B4FC"
                    android:textSize="@dimen/_12sdp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="3"
                    android:textColor="#64748B"
                    android:textSize="@dimen/_12sdp" />

            </RelativeLayout>

            <!-- Search Box -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                app:boxBackgroundColor="#1A1A2E"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
                app:boxCornerRadiusBottomStart="@dimen/_12sdp"
                app:boxCornerRadiusTopEnd="@dimen/_12sdp"
                app:boxCornerRadiusTopStart="@dimen/_12sdp"
                app:boxStrokeWidth="0dp"
                app:startIconDrawable="@drawable/search"
                app:startIconTint="#94A3B8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_contacts_bg"
                    android:hint="Search contacts..."
                    android:paddingStart="@dimen/_50sdp"
                    android:paddingVertical="@dimen/_12sdp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#9CA3AF" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Participants List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/contactsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/add_members_items" />

            <!-- Create Group Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateGroup"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_56sdp"
                android:layout_margin="@dimen/_16sdp"
                android:layout_marginBottom="@dimen/_50sdp"
                android:background="@drawable/create_group_button_bg"
                android:text="Create Group"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_16sdp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:icon="@drawable/forward"
                app:iconGravity="end"
                app:iconTint="@android:color/white" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Rotating Spinner Loader -->
    <ProgressBar
        android:id="@+id/loading"
        style="?android:attr/progressBarStyle"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_80sdp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>