<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/preview_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MediaPreviewActivity"
    android:background="#000000">

    <!-- ViewPager to swipe between selected media -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Close (X) button top-left -->
    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="@dimen/_80sdp"
        android:layout_height="@dimen/_80sdp"
        android:layout_margin="@dimen/_16sdp"
        android:src="@drawable/button_close"
        android:layout_gravity="top|start"
        app:tint="#FFFFFF" />

    <!-- Bottom overlay: caption input + send -->
    <LinearLayout
        android:id="@+id/bottomOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_12sdp"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:background="@drawable/backgroud_media_send_preview"
        android:layout_margin="@dimen/_12sdp"
        android:elevation="@dimen/_8sdp">

        <ImageView
            android:id="@+id/ivCameraIcon"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            android:src="@drawable/camera_button"
            android:layout_marginEnd="@dimen/_8sdp"
            app:tint="#FFFFFF" />

        <EditText
            android:id="@+id/etCaption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:textColor="#FFFFFF"
            android:hint="Add a caption..."
            android:textColorHint="#DDFFFFFF"
            android:padding="@dimen/_8sdp"
            android:maxLines="3" />

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="@dimen/_44sdp"
            android:layout_height="@dimen/_44sdp"
            android:src="@drawable/send_button" />
    </LinearLayout>
</FrameLayout>
