<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="84dp"
    android:background="@drawable/contact_bg"
    android:padding="10dp"
    android:layout_marginTop="@dimen/_10sdp">

    <!-- Avatar + small clock badge -->
    <FrameLayout
        android:id="@+id/avatarHolder"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_person"
            android:padding="5dp"
            android:contentDescription="@string/app_name"
            />

        <!-- little clock badge -->
        <View
            android:id="@+id/clockBadge"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_margin="2dp"
            android:background="@drawable/clock"/>
    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Bryan"
        android:fontFamily="@font/roboto_regular"
        android:textSize="18sp"
        android:textColor="#E0F1FF"
        android:layout_marginStart="@dimen/_10sdp"
        app:layout_constraintStart_toEndOf="@id/avatarHolder"
        app:layout_constraintTop_toTopOf="@id/avatarHolder"
        app:layout_constraintEnd_toStartOf="@id/rightTimeGroup"
        app:layout_constraintHorizontal_bias="0"/>

    <!-- Subtitle / last message -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="What do you think?"
        android:textSize="14sp"
        android:textColor="#A8ADBD"
        android:fontFamily="@font/roboto_regular"
        app:layout_constraintStart_toStartOf="@id/tvName"
        app:layout_constraintTop_toBottomOf="@id/tvName"
        app:layout_constraintEnd_toStartOf="@id/badgeUnread"
        app:layout_constraintBottom_toBottomOf="@id/avatarHolder"/>

    <!-- Right top: 18 min remain  -  4:30 PM -->
    <LinearLayout
        android:id="@+id/rightTimeGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/avatarHolder">

        <TextView
            android:id="@+id/tvRemain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18 min remain"
            android:textSize="12sp"
            android:fontFamily="@font/roboto_regular"
            android:textColor="#A8ADBD"/>

        <TextView
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  -  "
            android:textSize="12sp"
            android:fontFamily="@font/roboto_regular"
            android:textColor="#A8ADBD"/>

        <TextView
            android:visibility="gone"
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4:30 PM"
            android:textSize="12sp"
            android:fontFamily="@font/roboto_regular"
            android:textColor="#A8ADBD"/>
    </LinearLayout>

    <!-- Unread count pill -->
    <TextView
        android:visibility="gone"
        android:id="@+id/badgeUnread"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/bg_unread_pill"
        android:gravity="center"
        android:text="2"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/roboto_medium"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/avatarHolder"/>
</androidx.constraintlayout.widget.ConstraintLayout>
