<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kyber_bg_new"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:focusableInTouchMode="true">


    <TextView
        android:layout_marginTop="@dimen/_130sdp"
        android:id="@+id/secondxt"
        android:layout_centerHorizontal="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Display Name"
        android:fontFamily="@font/roboto_semibold"
        android:textSize="@dimen/_24sdp"
        android:textColor="@color/secondary_text_color"/>

    <TextView
        android:layout_marginTop="@dimen/_4sdp"
        android:layout_below="@id/secondxt"
        android:id="@+id/tvtermsDef"
        android:layout_centerHorizontal="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use your real name or any alias — change it\nanytime."
        android:fontFamily="@font/roboto_regular"
        android:textSize="@dimen/_12sdp"
        android:textAlignment="center"
        android:layout_gravity="center|bottom"
        android:textColor="#DADADA"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPwd"
        android:layout_width="@dimen/_300sdp"
        android:layout_height="wrap_content"
        android:layout_below="@id/secondxt"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/_60sdp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:boxBackgroundColor="@color/opacity_10_black_color"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
        app:boxCornerRadiusBottomStart="@dimen/_12sdp"
        app:boxCornerRadiusTopEnd="@dimen/_12sdp"
        app:boxCornerRadiusTopStart="@dimen/_12sdp"
        app:boxStrokeColor="@color/inputfield_outline_color"
        app:boxStrokeWidth="@dimen/_1sdp"
        app:errorIconDrawable="@null"
        app:hintEnabled="false"
       >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPwd"
            android:layout_width="@dimen/_300sdp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:hint="Display Name"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/white"
            android:textColorHint="@color/opacity_70_white_color"
            android:textSize="@dimen/_14sdp">

            <requestFocus />
        </com.google.android.material.textfield.TextInputEditText>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton

        android:id="@+id/btnPwd"
        android:textColor="@color/white"
        app:backgroundTint="@color/primary_color"
        android:layout_width="match_parent"
        android:fontFamily="@font/roboto_semibold"
        android:textSize="@dimen/_18sdp"
        android:layout_height="@dimen/_60sdp"
        app:cornerRadius="@dimen/_10sdp"
        android:layout_marginTop="20dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="@dimen/_20sdp"
        android:text="Continue"
        android:layout_marginHorizontal="@dimen/_20sdp"/>
</RelativeLayout>