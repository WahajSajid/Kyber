<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent"
    tools:context=".fragments.NetworkFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_25sdp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/heading_constrain_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <!-- Kyber VPN Icon -->
            <ImageView
                android:id="@+id/ivVpnIcon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/vpn_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="30dp"
                android:layout_marginStart="24dp"
                android:contentDescription="VPN Icon" />

            <!-- Kyber VPN Title -->
            <TextView
                android:id="@+id/tvVpnTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kyber VPN"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_16sdp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/ivVpnIcon"
                app:layout_constraintStart_toEndOf="@id/ivVpnIcon"
                android:layout_marginStart="12dp" />

            <!--Status Text View -->
            <TextView
                android:id="@+id/tvVpnStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: "
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintStart_toStartOf="@id/tvVpnTitle"
                app:layout_constraintTop_toBottomOf="@id/tvVpnTitle"
                android:layout_marginTop="4dp" />

            <!--Status Text View -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status"
                android:layout_width="@dimen/_92sdp"
                android:layout_height="@dimen/_20sdp"
                android:background="@drawable/connected_option_bg"
                app:cardCornerRadius="@dimen/_10sdp"
                app:cardElevation="0dp"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/tvVpnStatus"
                app:layout_constraintTop_toTopOf="@id/tvVpnStatus"
                app:layout_constraintBottom_toBottomOf="@id/tvVpnStatus">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/dot_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/dot"
                        android:paddingStart="@dimen/_7sdp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <!-- Add a TextView inside -->
                    <TextView
                        android:id="@+id/tvStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textStyle="bold"
                        android:paddingStart="@dimen/_10sdp"
                        app:layout_constraintStart_toEndOf="@id/dot_image"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:text="Protected"
                        android:textColor="#00AA5B"
                        android:textSize="13sp"
                        android:gravity="center" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            app:layout_constraintStart_toStartOf="@id/heading_constrain_layout"
            app:layout_constraintEnd_toEndOf="@id/heading_constrain_layout"
            app:layout_constraintTop_toBottomOf="@id/heading_constrain_layout">

            <!-- Disconnect Button -->
            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="@dimen/_115sdp"
                android:layout_height="@dimen/_27sdp"
                android:text="Disconnect"
                android:textColor="#EFF0F1"
                android:background="@drawable/disconnect_btn_bg"
                android:paddingHorizontal="17dp"
                android:paddingVertical="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/restart_connection_btn"
                app:layout_constraintHorizontal_chainStyle="packed" />

            <!-- Restart Connection Button -->
            <Button
                android:id="@+id/restart_connection_btn"
                android:layout_width="@dimen/_158sdp"
                android:layout_height="@dimen/_27sdp"
                android:text="Restart Connection"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="#EFF0F1"
                android:background="@drawable/restart_connection_btn"
                android:paddingHorizontal="17dp"
                android:paddingVertical="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnDisconnect" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <!-- Divider -->
        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#26263A"
            app:layout_constraintTop_toBottomOf="@id/buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/heading_tor_network"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/divider1">


            <!-- Kyber VPN Icon -->
            <ImageView
                android:id="@+id/tor_icon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/tor_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="30dp"
                android:layout_marginStart="24dp"
                android:contentDescription="VPN Icon" />

            <!-- Kyber VPN Title -->
            <TextView
                android:id="@+id/torVpnTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tor Network"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_16sdp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/tor_icon"
                app:layout_constraintStart_toEndOf="@id/tor_icon"
                android:layout_marginStart="@dimen/_10sdp" />

            <!--Status Text View -->
            <TextView
                android:id="@+id/torVpnStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: "
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="@dimen/_13sdp"
                app:layout_constraintStart_toStartOf="@id/torVpnTitle"
                app:layout_constraintTop_toBottomOf="@id/torVpnTitle"
                android:layout_marginTop="4dp" />

            <!--Status Text View -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tor_status"
                android:layout_width="@dimen/_92sdp"
                android:layout_height="@dimen/_20sdp"
                android:background="@drawable/connected_option_bg"
                app:cardCornerRadius="@dimen/_10sdp"
                app:cardElevation="0dp"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/torVpnStatus"
                app:layout_constraintTop_toTopOf="@id/torVpnStatus"
                app:layout_constraintBottom_toBottomOf="@id/torVpnStatus">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/dot_image1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/dot"
                        android:paddingStart="@dimen/_7sdp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <!-- Add a TextView inside -->
                    <TextView
                        android:id="@+id/torStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textStyle="bold"
                        android:paddingStart="@dimen/_10sdp"
                        app:layout_constraintStart_toEndOf="@id/dot_image1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:text="Protected"
                        android:textColor="#00AA5B"
                        android:textSize="13sp"
                        android:gravity="center" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Tor Description -->
        <LinearLayout
            android:id="@+id/bullet_list_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="26dp"
            app:layout_constraintTop_toBottomOf="@id/heading_tor_network">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- bullet -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/circle_dot" />

                <!-- text: label (bold) + description (normal) -->
                <TextView
                    android:id="@+id/item1_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/bullet_item1"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/circle_dot" />

                <TextView
                    android:id="@+id/item2_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/bullet_item2"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/circle_dot" />

                <TextView
                    android:id="@+id/item3_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/bullet_item3"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

        </LinearLayout>
        <!-- Divider -->
        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#26263A"
            app:layout_constraintTop_toBottomOf="@id/bullet_list_root"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="@dimen/_5sdp" />

        <!-- Post Quantum Title -->
        <LinearLayout
            android:id="@+id/pqc_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider2">
            <ImageView
                android:id="@+id/pqc_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/pqc_img"/>

            <TextView
                android:id="@+id/tvPostQuantumTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post Quantum Encryption"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/_8sdp"
                android:paddingBottom="@dimen/_2sdp"
                app:layout_constraintTop_toBottomOf="@id/divider2"
                app:layout_constraintStart_toStartOf="parent" />


        </LinearLayout>

        <!-- Public key / Generate button block — converted to LinearLayouts (keeps original alignment) -->

        <!-- Top row: Title (left) and Last update group (right) -->
        <LinearLayout
            android:id="@+id/public_key_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/pqc_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingStart="@dimen/_25sdp"
            android:paddingEnd="@dimen/_25sdp"
            android:layout_marginTop="@dimen/_20sdp">

            <!-- Title (left) -->
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_public_key"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Spacer to push last_update_group to the right -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Last update (right). badge is separate so you can style it. -->
            <LinearLayout
                android:id="@+id/last_update_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/last_update_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/last_update"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/_14sdp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/last_update_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/hours_ago_bg"
                    android:text="@string/last_update_age"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/lock_img"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:src="@drawable/group_1171276116" />
            </LinearLayout>
        </LinearLayout>

        <!-- Public key display (rounded input-like box).
             Using match_parent so paddingStart/End applied from parent keep it centered visually. -->

        <!-- Generate new key button centered -->


        <TextView
            android:id="@+id/public_key_field"
            android:layout_width="0dp"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginStart="@dimen/_30sdp"
            android:layout_marginEnd="@dimen/_30sdp"
            android:layout_marginTop="@dimen/_16sdp"
            android:background="@drawable/public_key_bg"
            android:gravity="center"
            android:text="@string/sample_public_key"
            android:textColor="#E6EEF6"
            android:textSize="@dimen/_16sdp"
            app:layout_constraintTop_toBottomOf="@id/public_key_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="SpUsage" />



        <Button
            android:id="@+id/generate_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/generate_button"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#5F99F6"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/public_key_field"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_15sdp" />



    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>