<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/_240sdp"
    android:layout_height="wrap_content"
    android:layout_marginRight="@dimen/_18sdp"
    android:layout_marginLeft="@dimen/_18sdp"
    android:background="@drawable/disappearing_messages_dialog_bg">

    <LinearLayout
        android:id="@+id/linear_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/_18sdp">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Search Privacy"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_18sdp"
            android:textStyle="bold" />

        <!-- Centered icon -->
        <ImageView
            android:id="@+id/centerIcon"
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_41sdp"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_14sdp"
            android:src="@drawable/privacy_profile"
            app:tint="@color/white" />

        <!-- Description -->
        <TextView
            android:id="@+id/description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_12sdp"
            android:lineSpacingExtra="@dimen/_2sdp"
            android:text="Configure whether your profile\n is discoverable via your unique\n key."
            android:textColor="#CDE6FF"
            android:textSize="@dimen/_13sdp" />

        <!-- Divider -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_1sdp"
            android:layout_marginTop="@dimen/_30sdp"
            android:background="#26263A" />

    </LinearLayout>


    <!-- Options list -->
    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/_2sdp"
        app:layout_constraintTop_toBottomOf="@id/linear_layout"
        android:paddingBottom="@dimen/_6sdp">


        <!-- Option: Off (selected) -->
        <LinearLayout
            android:id="@+id/layout_on"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_56sdp"
            android:gravity="center_vertical"
            android:paddingRight="@dimen/_20sdp"
            android:paddingLeft="@dimen/_20sdp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/opt_on"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="On"
                android:textColor="#00AA5B"
                android:textSize="@dimen/_16sdp"
                android:textStyle="bold" />

            <!-- show checked circle with check icon -->
            <ImageView
                android:id="@+id/radio_on"
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:src="@drawable/radio_checked"
                android:buttonTint="@null" />
        </LinearLayout>



        <!-- Divider -->
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_1sdp"
            android:background="#26263A" />


        <!-- Option: Off (selected) -->
        <LinearLayout
            android:id="@+id/layout_off"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_56sdp"
            android:gravity="center_vertical"
            android:paddingRight="@dimen/_20sdp"
            android:paddingLeft="@dimen/_20sdp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/opt_off"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Off"
                android:textColor="#FF6B6B"
                android:textSize="@dimen/_16sdp"
                android:textStyle="bold" />

            <!-- show checked circle with check icon -->
            <ImageView
                android:id="@+id/radio_off"
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:src="@drawable/radio_checked"
                android:buttonTint="@null" />
        </LinearLayout>

    </LinearLayout>









</androidx.constraintlayout.widget.ConstraintLayout>