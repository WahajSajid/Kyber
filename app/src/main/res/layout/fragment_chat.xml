<?xml version="1.0" encoding="utf-8"?>
<!--
    DIFF from original:
    1. Added <include id="requestActionBar"> at bottom, visibility=gone by default.
       ChatFragment shows it and hides bottom_items_layout when coming_from="message_request".
    2. Changed rvMsg bottom constraint to reference a new barrier that picks
       either requestActionBar or bottom_items_layout depending on which is visible.
       (Handled in code via constraint changes, not needed in XML since we just
        anchor both to bottom of parent and let code toggle visibility.)
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".fragments.ChatListFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMsg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/_6sdp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_14sdp"
        app:layout_constraintBottom_toTopOf="@id/bottom_items_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        tools:listitem="@layout/msg_list_item" />

    <!-- BLUR/DIM OVERLAY -->
    <View
        android:id="@+id/blurOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true" />

    <!-- ACTION MENU OVERLAY -->
    <include
        layout="@layout/msg_action_menu"
        android:id="@+id/actionMenuOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="11dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- NORMAL COMPOSE BOTTOM BAR — hidden in request mode -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_items_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/emojiPickerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Lock Popup for Audio Recording -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lockPopup"
            android:layout_width="@dimen/_52sdp"
            android:layout_height="@dimen/_93sdp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/lock_popup_bg"
            android:elevation="@dimen/_8sdp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_8sdp"
            android:paddingTop="@dimen/_14sdp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/unLockedRecordingBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.796">

            <ImageView
                android:id="@+id/ivLockIcon"
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/lock_ic"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/tvLockChevrons"
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:src="@drawable/arrows_up"
                app:layout_constraintTop_toBottomOf="@id/ivLockIcon"
                app:layout_constraintStart_toStartOf="@id/ivLockIcon"
                app:layout_constraintEnd_toEndOf="@id/ivLockIcon"
                android:textSize="@dimen/_13sdp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Unlocked Recording Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/unLockedRecordingBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/_120sdp"
            android:background="@drawable/recording_bottom_bg"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/bottom_sheet"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivRecordingMicUnlocked"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/mic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FF4444" />

            <TextView
                android:id="@+id/tvRecordingTimerUnlocked"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="0:00"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp"
                app:layout_constraintBottom_toBottomOf="@+id/ivRecordingMicUnlocked"
                app:layout_constraintStart_toEndOf="@+id/ivRecordingMicUnlocked"
                app:layout_constraintTop_toTopOf="@+id/ivRecordingMicUnlocked" />

            <TextView
                android:id="@+id/tvSlideToCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/_5sdp"
                android:fontFamily="@font/roboto_regular"
                android:text="&lt; Slide to cancel"
                android:textColor="#969A9F"
                android:textSize="@dimen/_14sdp"
                app:layout_constraintBottom_toBottomOf="@+id/ivRecordingMicUnlocked"
                app:layout_constraintEnd_toStartOf="@+id/tappedMicIc"
                app:layout_constraintStart_toEndOf="@+id/tvRecordingTimerUnlocked"
                app:layout_constraintTop_toTopOf="@+id/ivRecordingMicUnlocked" />

            <ImageView
                android:id="@+id/tappedMicIc"
                android:layout_width="@dimen/_63sdp"
                android:layout_height="@dimen/_63sdp"
                android:layout_marginEnd="@dimen/_9sdp"
                android:src="@drawable/tapped_lock_ic"
                app:layout_constraintBottom_toBottomOf="@+id/ivRecordingMicUnlocked"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/ivRecordingMicUnlocked"
                tools:layout_editor_absoluteX="358dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Locked Recording Bar -->
        <LinearLayout
            android:id="@+id/lockedRecordingBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/_120sdp"
            android:background="@drawable/recording_bottom_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingTop="@dimen/_7sdp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/bottom_sheet"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/ivRecordDelete"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/_4sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/trash_bin_ic"
                app:tint="#969A9F" />

            <ImageView
                android:id="@+id/ivRecordPause"
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp"
                android:layout_marginStart="@dimen/_6sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/_4sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/pause_icon_0"
                app:tint="#FFFFFF" />

            <app.secure.kyber.Other.WaveformView
                android:id="@+id/waveformRecording"
                android:layout_width="0dp"
                android:layout_height="@dimen/_36sdp"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvRecordingTimer"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="0:00"
                android:textColor="@color/white"
                android:textSize="@dimen/_12sdp" />

            <ImageView
                android:id="@+id/ivRecordingMic"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:layout_marginStart="@dimen/_4sdp"
                android:padding="@dimen/_4sdp"
                android:scaleType="fitCenter"
                android:src="@drawable/mic"
                app:tint="#FF4444" />

            <ImageView
                android:id="@+id/ivRecordSend"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginStart="@dimen/_6sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/send_button"
                app:tint="@null" />

        </LinearLayout>

        <!-- Expandable bottom sheet (compose UI) -->
        <LinearLayout
            android:id="@+id/bottom_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bottom_nav_bar_bg_png"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_14sdp"
            android:paddingBottom="@dimen/_10sdp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Preview strip -->
            <LinearLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="@dimen/_6sdp"
                android:paddingBottom="@dimen/_6sdp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_140sdp"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/_6sdp"
                    android:paddingEnd="@dimen/_6sdp"
                    android:overScrollMode="never"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Composer row -->
            <RelativeLayout
                android:id="@+id/llActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivAdd"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_4sdp"
                    android:padding="@dimen/xXXSmallPadding"
                    android:scaleType="fitCenter"
                    android:src="@drawable/add_content"
                    app:tint="@null" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@id/icon_layout"
                    android:layout_toRightOf="@id/ivAdd"
                    app:boxBackgroundColor="@color/opacity_10_black_color"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="@dimen/_18sdp"
                    app:boxCornerRadiusBottomStart="@dimen/_18sdp"
                    app:boxCornerRadiusTopEnd="@dimen/_18sdp"
                    app:boxCornerRadiusTopStart="@dimen/_18sdp"
                    app:boxStrokeColor="#30009FFF"
                    app:boxStrokeWidth="@dimen/_1sdp"
                    app:endIconDrawable="@drawable/emoji_icon"
                    app:endIconMode="custom"
                    android:visibility="visible"
                    app:endIconTint="@color/white"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_regular"
                        android:gravity="center_vertical|start"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="4"
                        android:minHeight="@dimen/_40sdp"
                        android:paddingStart="@dimen/_12sdp"
                        android:paddingTop="@dimen/_8sdp"
                        android:paddingEnd="@dimen/_12sdp"
                        android:paddingBottom="@dimen/_8sdp"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_16sdp" />

                </com.google.android.material.textfield.TextInputLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/icon_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivCamera"
                        android:layout_width="@dimen/_32sdp"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_marginStart="@dimen/xXXSmallPadding"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/camera"
                        android:visibility="visible"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:tint="@null" />

                    <ImageView
                        android:id="@+id/ivMic"
                        android:layout_width="@dimen/_32sdp"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginStart="@dimen/xXXSmallPadding"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/mic"
                        android:visibility="visible"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivCamera"
                        app:tint="@null" />

                    <ImageView
                        android:id="@+id/ivSend"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginStart="@dimen/xXXSmallPadding"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/send_button"
                        android:visibility="gone"
                        app:tint="@null" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </RelativeLayout>

            <!-- Content Menu -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/contentMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/_25sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/llGallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/llCamera"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:id="@+id/ivGallery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/gallery_icn"
                        app:tint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Gallery"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/llContact"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/llGallery">

                    <ImageView
                        android:id="@+id/ivvCamera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/camera_ic"
                        app:tint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Camera"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/llDocument"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/llCamera">

                    <ImageView
                        android:id="@+id/ivContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/contact_ic"
                        app:tint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Contact"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llDocument"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@+id/llAudio"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/llContact">

                    <ImageView
                        android:id="@+id/ivDocument"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/document_ic"
                        app:tint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Document"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_3sdp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/llDocument">

                    <ImageView
                        android:id="@+id/ivAudio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="@dimen/xXXSmallPadding"
                        android:scaleType="fitCenter"
                        android:src="@drawable/audio_ic"
                        app:tint="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Audio"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12sdp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============================================================
         REQUEST MODE ACTION BAR
         Shown INSTEAD of bottom_items_layout when coming_from="message_request".
         Hidden by default; ChatFragment makes it visible and hides bottom_items_layout.
         ============================================================ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/requestActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="@dimen/_24sdp"
        android:paddingVertical="@dimen/_12sdp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/emojiPickerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <TextView
            android:id="@+id/block_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Block"
            android:textSize="@dimen/_18sdp"
            android:textColor="#FF4141"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/instruction_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allow them to send you a message and \n share your name and photo with them? \n They won't be notified that you've seen \n their message until you accept."
            android:textSize="@dimen/_18sdp"
            android:textColor="#969A9F"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/block_txt"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRejectRequest"
            android:layout_width="@dimen/_130sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:layout_weight="1"
            android:text="Reject"
            android:textAllCaps="false"
            android:textColor="#FF4444"
            android:textSize="@dimen/_16sdp"
            android:textStyle="bold"
            app:backgroundTint="#1AFF4444"
            android:layout_marginTop="@dimen/_20sdp"
            app:cornerRadius="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@id/instruction_text"
            app:layout_constraintEnd_toStartOf="@+id/btnAcceptRequest"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#FF4444"
            app:strokeWidth="@dimen/_1sdp"
            tools:layout_editor_absoluteY="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptRequest"
            android:layout_width="@dimen/_130sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_weight="1"
            android:text="Accept"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="@dimen/_16sdp"
            android:textStyle="bold"

            android:layout_marginTop="@dimen/_20sdp"
            app:backgroundTint="#5F99F6"
            app:cornerRadius="@dimen/_12sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/instruction_text"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/btnRejectRequest"
            tools:layout_editor_absoluteY="12dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Emoji Picker View -->
    <FrameLayout
        android:id="@+id/emojiPickerContainer"
        android:layout_width="0dp"
        android:layout_height="@dimen/_250sdp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>