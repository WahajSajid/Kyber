<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="@dimen/_20sdp">

    <TextView
        android:id="@+id/appname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_10sdp"
        android:fontFamily="@font/roboto_medium"
        android:text="New Message"
        android:textColor="@color/primary_text_color"
        android:textSize="@dimen/_20sdp" />

    <TextView
        android:id="@+id/desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_3sdp"
        android:fontFamily="@font/roboto_medium"
        android:text="Enter or Scan the Kyber Chat ID of the person you'd like to connect with."
        android:textColor="#DADADA"
        android:gravity="center"
        android:textSize="@dimen/_14sdp" />

    <TextView
        android:id="@+id/tvId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_15sdp"
        android:fontFamily="@font/roboto_medium"
        android:text="Kyber ID"
        android:textColor="@color/opacity_70_white_color"
        android:textSize="@dimen/_14sdp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:boxBackgroundColor="@color/opacity_10_black_color"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
        app:boxCornerRadiusBottomStart="@dimen/_12sdp"
        app:boxCornerRadiusTopEnd="@dimen/_12sdp"
        app:boxCornerRadiusTopStart="@dimen/_12sdp"
        app:boxStrokeColor="@color/inputfield_outline_color"
        app:boxStrokeWidth="@dimen/_1sdp"
        app:errorIconDrawable="@null"
        app:boxStrokeErrorColor="#31429CCC"
        app:errorTextColor="#31429CCC"
        app:cursorColor="@color/primary_color"
        app:hintEnabled="false"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/qr"
        app:endIconTint="@color/white"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_regular"
            android:hint="Enter ID"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/white"
            android:textColorHint="@color/opacity_70_white_color"
            android:textSize="@dimen/_14sdp">
            <requestFocus />
        </com.google.android.material.textfield.TextInputEditText>

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/_25sdp"
        android:layout_marginBottom="@dimen/_10sdp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/_46sdp"
            android:background="@android:color/transparent"
            android:fontFamily="@font/roboto_semibold"
            android:textColor="#969A9F"
            android:textSize="@dimen/_16sdp"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/_10sdp"
            android:text="Cancel"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="@dimen/_46sdp"
            app:backgroundTint="#5F99F6"
            android:fontFamily="@font/roboto_semibold"
            android:textColor="@color/white"
            android:textSize="@dimen/_16sdp"
            app:cornerRadius="@dimen/_6sdp"
            android:text="Message"/>
    </LinearLayout>
</LinearLayout>
