<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.AddMembersFragment"
    android:background="@android:color/transparent">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="@dimen/_16sdp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:src="@drawable/back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Group"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_20sdp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="@dimen/_16sdp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_16sdp">

            <!-- Group Details Section -->
            <TextView
                android:id="@+id/tvGroupDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GROUP DETAILS"
                android:textColor="#A5B4FC"
                android:textSize="@dimen/_12sdp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:letterSpacing="0.05" />


                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGroupName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/_20sdp"
                    android:hint="Enter Group Name (Optional)"
                    android:background="@drawable/group_name_edit_text_bg"
                    android:textColor="@android:color/white"
                    android:textColorHint="#6B6B8D" />


            <!-- Anonymous Mode Card -->

                <LinearLayout
                    android:id="@+id/cvAnonymousMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/_30sdp"
                    android:background="@drawable/creator_view_expanded_view_bg"
                    android:padding="@dimen/_16sdp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivAnonymousIcon"
                            android:layout_width="@dimen/_24sdp"
                            android:layout_height="@dimen/_24sdp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/deselected_overlay_anonymous_ic"
                            />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/_12sdp"
                            android:layout_toEndOf="@id/ivAnonymousIcon"
                            android:layout_toStartOf="@id/switchAnonymous"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Anonymous Mode"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_17sdp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Temporary &amp; Encrypted"
                                android:textColor="#94A3B8"
                                android:textSize="@dimen/_12sdp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAnonymous"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@android:color/white"
                            app:trackTint="@color/switch_track_color" />

                    </RelativeLayout>

                    <!-- Creator View Only Section (Initially Hidden) -->
                    <LinearLayout
                        android:id="@+id/llCreatorViewOnly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:orientation="vertical"
                        android:padding="@dimen/_12sdp"
                        android:visibility="visible">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/_100sdp"
                            android:padding="@dimen/_10sdp"
                            android:background="@drawable/creator_only_view_bg">

                            <ImageView
                                android:id="@+id/ivShieldIcon"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_41sdp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                android:src="@drawable/shield_icon" />

                            <TextView
                                android:id="@+id/creator_view_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_8sdp"
                                android:layout_marginTop="@dimen/_5sdp"
                                android:layout_toEndOf="@id/ivShieldIcon"
                                app:layout_constraintTop_toTopOf="@id/ivShieldIcon"
                                app:layout_constraintStart_toEndOf="@id/ivShieldIcon"
                                android:text="Creator View Only"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/_14sdp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_8sdp"
                                android:layout_below="@id/creator_view_text"
                                android:layout_marginStart="@dimen/_6sdp"
                                app:layout_constraintTop_toBottomOf="@id/creator_view_text"
                                app:layout_constraintStart_toEndOf="@id/ivShieldIcon"
                                android:text="Members will see each other as &quot;Anonymous User&quot; or Pseudonyms."
                                android:textColor="#B0B0D0"
                                android:textSize="@dimen/_12sdp" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Time Options -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/small_timer_ic"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/small_timer_ic"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Creator View Only"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:layout_marginStart="@dimen/_5sdp"
                                    android:textSize="@dimen/_12sdp" />

                            </LinearLayout>

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/time_buttons_layout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_12sdp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/one_hour"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_38sdp"
                                    android:layout_marginEnd="@dimen/_4sdp"
                                    android:background="@drawable/time_buttons_bg"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="1h"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/_14sdp"
                                    app:backgroundTint="@null"
                                    app:cornerRadius="@dimen/_8sdp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toStartOf="@+id/six_hours"
                                    app:layout_constraintHorizontal_weight="1"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/six_hours"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_38sdp"
                                    android:layout_marginHorizontal="@dimen/_4sdp"
                                    android:background="@drawable/time_buttons_bg"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="6h"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/_14sdp"
                                    app:backgroundTint="@null"
                                    app:cornerRadius="@dimen/_8sdp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toStartOf="@+id/twenty_four_hour"
                                    app:layout_constraintHorizontal_weight="1"
                                    app:layout_constraintStart_toEndOf="@+id/one_hour"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/twenty_four_hour"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_38sdp"
                                    android:layout_marginHorizontal="@dimen/_4sdp"
                                    android:background="@drawable/time_buttons_bg"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="24h"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/_14sdp"
                                    app:backgroundTint="@null"
                                    app:cornerRadius="@dimen/_8sdp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toStartOf="@+id/custom"
                                    app:layout_constraintHorizontal_weight="1"
                                    app:layout_constraintStart_toEndOf="@+id/six_hours"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/custom"
                                    style="@style/Widget.MaterialComponents.Button"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/_38sdp"
                                    android:layout_marginStart="4dp"
                                    android:background="@drawable/time_buttons_bg"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="Custom"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/_13sdp"
                                    app:backgroundTint="@null"
                                    app:cornerRadius="@dimen/_8sdp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintHorizontal_weight="1.2"
                                    app:layout_constraintStart_toEndOf="@+id/twenty_four_hour"
                                    app:layout_constraintTop_toTopOf="parent" />

                            </androidx.constraintlayout.widget.ConstraintLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>


            <!-- Participants Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:id="@+id/tvParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="PARTICIPANTS"
                    android:textColor="#A5B4FC"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="3 selected"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

            </RelativeLayout>

            <!-- Search Box -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:boxBackgroundColor="#1A1A2E"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeWidth="0dp"
                app:startIconDrawable="@drawable/search"
                app:startIconTint="#94A3B8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search contacts..."
                    android:paddingStart="@dimen/_50sdp"
                    android:background="@drawable/search_contacts_bg"
                    android:textColor="@android:color/white"
                    android:textColorHint="#9CA3AF"
                    android:paddingVertical="12dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Participants List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/contactsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/add_members_items" />

            <!-- Spacer for button -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Create Group Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateGroup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:background="@drawable/create_group_button_bg"
        android:text="Create Group"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:icon="@drawable/forward"
        app:iconGravity="end"
        app:iconTint="@android:color/white"
        app:backgroundTint="@null" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
